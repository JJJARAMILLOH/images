  <block type="procedures_defnoreturn" id="PROC_UPDATE_WINRATE" x="400" y="1500">
    <field name="NAME">Update_Winrate</field>
    <statement name="STACK">
      <block type="controls_if" id="CHECK_TRADES_GT_0">
        <value name="IF0">
          <block type="logic_compare" id="TRADES_GT_ZERO">
            <field name="OP">GT</field>
            <value name="A">
              <block type="variables_get" id="GET_SESS_TRADES">
                <field name="VAR" id="SESSION_TRADES_001" variabletype="">Session_Trades</field>
              </block>
            </value>
            <value name="B">
              <block type="math_number" id="ZERO_TRADES"><field name="NUM">0</field></block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="CALC_WINRATE">
            <field name="VAR" id="WINRATE_001" variabletype="">Session_Winrate</field>
            <value name="VALUE">
              <block type="math_round" id="ROUND_WINRATE">
                <field name="OP">ROUND</field>
                <value name="NUM">
                  <shadow type="math_number" id="WR_ROUND_SHADOW"><field name="NUM">3.1</field></shadow>
                  <block type="math_arithmetic" id="WR_CALC">
                    <field name="OP">DIVIDE</field>
                    <value name="A">
                      <shadow type="math_number" id="WR_SHADOW_A"><field name="NUM">1</field></shadow>
                      <block type="math_arithmetic" id="WR_MULTIPLY">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <shadow type="math_number" id="WR_M_SHADOW"><field name="NUM">1</field></shadow>
                          <block type="variables_get" id="GET_WINS_WR">
                            <field name="VAR" id="SESSION_WINS_001" variabletype="">Session_Wins</field>
                          </block>
                        </value>
                        <value name="B">
                          <shadow type="math_number" id="WR_100"><field name="NUM">100</field></shadow>
                        </value>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="WR_SHADOW_B"><field name="NUM">1</field></shadow>
                      <block type="variables_get" id="GET_TRADES_WR">
                        <field name="VAR" id="SESSION_TRADES_001" variabletype="">Session_Trades</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
          </block>
        </statement>
      </block>
    </statement>
  </block>
  <block type="procedures_defnoreturn" id="PROC_UPDATE_PEAK" x="400" y="1700">
    <field name="NAME">Update_Peak_Drawdown</field>
    <comment pinned="false" h="80" w="160">Trailing drawdown protection - ajusta threshold dinámicamente</comment>
    <statement name="STACK">
      <block type="controls_if" id="CHECK_NEW_PEAK">
        <value name="IF0">
          <block type="logic_compare" id="PROFIT_GT_PEAK">
            <field name="OP">GT</field>
            <value name="A">
              <block type="total_profit" id="GET_PROF_PEAK"></block>
            </value>
            <value name="B">
              <block type="variables_get" id="GET_PEAK">
                <field name="VAR" id="PEAK_PROFIT_001" variabletype="">Peak_Profit</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="UPDATE_PEAK">
            <field name="VAR" id="PEAK_PROFIT_001" variabletype="">Peak_Profit</field>
            <value name="VALUE">
              <block type="total_profit" id="SET_PEAK_PROF"></block>
            </value>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="CHECK_DRAWDOWN_ADJUST">
            <value name="IF0">
              <block type="logic_compare" id="LOSING_STREAK_HIGH">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="variables_get" id="GET_STREAK_DYN">
                    <field name="VAR" id="STREAK_001" variabletype="">Current_Streak</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="STREAK_3"><field name="NUM">3</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="INCREASE_THRESHOLD">
                <field name="VAR" id="DYN_THRESH_001" variabletype="">Dynamic_Threshold</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="ADD_TO_THRESH">
                    <field name="OP">ADD</field>
                    <value name="A">
                      <shadow type="math_number" id="THRESH_ADD_SHADOW"><field name="NUM">1</field></shadow>
                      <block type="variables_get" id="GET_BASE_THRESH_DYN">
                        <field name="VAR" id="BASE_THRESH_001" variabletype="">Base_Threshold</field>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="THRESH_ADD_VAL"><field name="NUM">4</field></shadow>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="INCREASE_CONF_MIN">
                    <field name="VAR" id="CONFLUENCE_MIN_001" variabletype="">Confluence_Min</field>
                    <value name="VALUE">
                      <block type="math_number" id="CONF_MIN_4"><field name="NUM">4</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="controls_if" id="CHECK_RESET_THRESHOLD">
                <value name="IF0">
                  <block type="logic_operation" id="NO_STREAK_CHECK">
                    <field name="OP">AND</field>
                    <value name="A">
                      <block type="logic_compare" id="STREAK_IS_0">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get" id="GET_STREAK_RESET">
                            <field name="VAR" id="STREAK_001" variabletype="">Current_Streak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="ZERO_STR"><field name="NUM">0</field></block>
                        </value>
                      </block>
                    </value>
                    <value name="B">
                      <block type="logic_compare" id="STREAK_TYPE_WIN">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get" id="GET_STR_TYPE_RESET">
                            <field name="VAR" id="STREAK_TYPE_001" variabletype="">Streak_Type</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="text" id="WIN_TXT_RESET"><field name="TEXT">win</field></block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="RESET_DYN_THRESH">
                    <field name="VAR" id="DYN_THRESH_001" variabletype="">Dynamic_Threshold</field>
                    <value name="VALUE">
                      <block type="variables_get" id="RESET_TO_BASE_THRESH">
                        <field name="VAR" id="BASE_THRESH_001" variabletype="">Base_Threshold</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="RESET_CONF_MIN">
                        <field name="VAR" id="CONFLUENCE_MIN_001" variabletype="">Confluence_Min</field>
                        <value name="VALUE">
                          <block type="math_number" id="CONF_MIN_3_RESET"><field name="NUM">3</field></block>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
