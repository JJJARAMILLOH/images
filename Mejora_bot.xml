                <field name="OP">GTE</field>
                <value name="A">
                  <block type="procedures_callreturn" id="CALL_EVEN_CONF1">
                    <mutation name="LD Even (%)"></mutation>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="CONF1_THRESH"><field name="NUM">56</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="math_change" id="ADD_CONF_SHORT_EVEN">
                <field name="VAR" id="CONFLUENCE_001" variabletype="">Confluence_Score</field>
                <value name="DELTA">
                  <shadow type="math_number" id="CONF_ADD_1"><field name="NUM">1</field></shadow>
                </value>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="SHORT_ODD_HIGH">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="procedures_callreturn" id="CALL_ODD_CONF1">
                    <mutation name="LD Odd (%)"></mutation>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="CONF1_THRESH_ODD"><field name="NUM">56</field></block>
