                      <block type="logic_operation" id="TREND_EVEN_RISING">
                        <field name="OP">AND</field>
                        <value name="A">
                          <block type="logic_compare" id="EVEN_GT_PREV">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="procedures_callreturn" id="CALL_EVEN_TREND">
                                <mutation name="LD Even (%)"></mutation>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="GET_PREV_EVEN">
                                <field name="VAR" id="PREV_EVEN_001" variabletype="">Prev_Even_Pct</field>
