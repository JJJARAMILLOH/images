                <value name="IF1">
                  <block type="logic_compare" id="ODD_VERY_HIGH">
                    <field name="OP">GTE</field>
                    <value name="A">
                      <block type="procedures_callreturn" id="CALL_ODD_CONF2">
                        <mutation name="LD Odd (%)"></mutation>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number" id="CONF2_THRESH_ODD"><field name="NUM">64</field></block>
                    </value>
                  </block>
                </value>
                <statement name="DO1">
                  <block type="math_change" id="ADD_CONF_STRONG_ODD">
                    <field name="VAR" id="CONFLUENCE_001" variabletype="">Confluence_Score</field>
                    <value name="DELTA">
                      <shadow type="math_number" id="CONF_ADD_2B"><field name="NUM">2</field></shadow>
                    </value>
                  </block>
                </statement>
                <next>
                  <block type="controls_if" id="CONF_CHECK_3_TREND">
                    <mutation elseif="1"></mutation>
