                    <value name="IF1">
                      <block type="logic_operation" id="TREND_ODD_RISING">
                        <field name="OP">AND</field>
                        <value name="A">
                          <block type="logic_compare" id="ODD_GT_PREV">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="procedures_callreturn" id="CALL_ODD_TREND">
                                <mutation name="LD Odd (%)"></mutation>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="GET_PREV_ODD">
                                <field name="VAR" id="PREV_ODD_001" variabletype="">Prev_Odd_Pct</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="logic_compare" id="ODD_ABOVE_50">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="procedures_callreturn" id="CALL_ODD_50">
                                <mutation name="LD Odd (%)"></mutation>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="FIFTY_2"><field name="NUM">52</field></block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO1">
                      <block type="math_change" id="ADD_CONF_TREND_ODD">
                        <field name="VAR" id="CONFLUENCE_001" variabletype="">Confluence_Score</field>
                        <value name="DELTA">
                          <shadow type="math_number" id="CONF_ADD_TREND2"><field name="NUM">1</field></shadow>
                        </value>
                      </block>
                    </statement>
                    <next>
                      <block type="controls_if" id="CONF_CHECK_4_WINRATE">
                        <value name="IF0">
                          <block type="logic_compare" id="WR_ABOVE_55">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="variables_get" id="GET_WR_CONF">
                                <field name="VAR" id="WINRATE_001" variabletype="">Session_Winrate</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="WR_THRESH"><field name="NUM">55</field></block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="math_change" id="ADD_CONF_WINRATE">
                            <field name="VAR" id="CONFLUENCE_001" variabletype="">Confluence_Score</field>
                            <value name="DELTA">
                              <shadow type="math_number" id="CONF_ADD_WR"><field name="NUM">1</field></shadow>
                            </value>
