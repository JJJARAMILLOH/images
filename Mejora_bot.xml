  <block type="procedures_defnoreturn" id="PROC_FIB_MART" x="400" y="600">
    <field name="NAME">Fibonacci_Martingale</field>
    <comment pinned="false" h="80" w="160">Martingale basado en Fibonacci - Escala progresiva inteligente con cap</comment>
    <statement name="STACK">
      <block type="math_change" id="INC_FIB_IDX">
        <field name="VAR" id="FIB_IDX_001" variabletype="">Fib_Index</field>
        <value name="DELTA">
          <shadow type="math_number" id="FIB_INC_VAL"><field name="NUM">1</field></shadow>
        </value>
        <next>
          <block type="controls_if" id="CAP_FIB_INDEX">
            <value name="IF0">
              <block type="logic_compare" id="FIB_GT_12">
                <field name="OP">GT</field>
                <value name="A">
                  <block type="variables_get" id="GET_FIB_IDX_CAP">
                    <field name="VAR" id="FIB_IDX_001" variabletype="">Fib_Index</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="FIB_MAX_IDX"><field name="NUM">8</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="RESET_FIB_TO_8">
                <field name="VAR" id="FIB_IDX_001" variabletype="">Fib_Index</field>
                <value name="VALUE">
                  <block type="math_number" id="FIB_CAP_VAL"><field name="NUM">8</field></block>
                </value>
              </block>
            </statement>
            <next>
              <block type="variables_set" id="CALC_FIB_STAKE">
                <field name="VAR" id="X[(S;ATE$Dbs3flXN{-m" variabletype="">Initial Amount</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="FIB_MULTIPLY_STAKE">
                    <field name="OP">MULTIPLY</field>
                    <value name="A">
                      <shadow type="math_number" id="FIB_MULT_SHADOW"><field name="NUM">1</field></shadow>
                      <block type="variables_get" id="GET_BASE_FOR_FIB">
                        <field name="VAR" id="BASE_STAKE_001" variabletype="">Base_Stake</field>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="FIB_MULT_SHADOW2"><field name="NUM">1</field></shadow>
                      <block type="lists_getIndex" id="GET_FIB_MULTIPLIER">
                        <mutation statement="false" at="true"></mutation>
                        <field name="MODE">GET</field>
                        <field name="WHERE">FROM_START</field>
                        <value name="VALUE">
                          <block type="variables_get" id="GET_FIB_SEQ">
                            <field name="VAR" id="FIB_SEQ_001" variabletype="">Fib_Sequence</field>
                          </block>
                        </value>
                        <value name="AT">
                          <block type="variables_get" id="GET_FIB_IDX_FOR_LIST">
                            <field name="VAR" id="FIB_IDX_001" variabletype="">Fib_Index</field>
                          </block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="CHECK_ANTI_TILT_REDUCTION">
                    <value name="IF0">
                      <block type="logic_compare" id="TILT_IS_TRUE">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get" id="GET_TILT_MODE">
                            <field name="VAR" id="ANTI_TILT_001" variabletype="">Anti_Tilt_Mode</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="logic_boolean" id="TILT_TRUE_CHECK"><field name="BOOL">TRUE</field></block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="variables_set" id="REDUCE_STAKE_TILT">
                        <field name="VAR" id="X[(S;ATE$Dbs3flXN{-m" variabletype="">Initial Amount</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="TILT_REDUCE_CALC">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <shadow type="math_number" id="TILT_R_SHADOW"><field name="NUM">1</field></shadow>
                              <block type="variables_get" id="GET_STAKE_TILT">
                                <field name="VAR" id="X[(S;ATE$Dbs3flXN{-m" variabletype="">Initial Amount</field>
                              </block>
                            </value>
                            <value name="B">
                              <shadow type="math_number" id="TILT_FACTOR"><field name="NUM">0.75</field></shadow>
                            </value>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <next>
                      <block type="controls_if" id="CHECK_MAX_STAKE_CAP">
                        <value name="IF0">
                          <block type="logic_compare" id="STAKE_GT_MAX">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="variables_get" id="GET_STAKE_CAP_CHECK">
                                <field name="VAR" id="X[(S;ATE$Dbs3flXN{-m" variabletype="">Initial Amount</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="MAX_STAKE_VALUE"><field name="NUM">15</field></block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="variables_set" id="CAP_STAKE_AT_MAX">
                            <field name="VAR" id="X[(S;ATE$Dbs3flXN{-m" variabletype="">Initial Amount</field>
                            <value name="VALUE">
                              <block type="math_number" id="MAX_STAKE_SET"><field name="NUM">15</field></block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="procedures_defnoreturn" id="PROC_CALC_CONFLUENCE" x="400" y="900">
    <field name="NAME">Calculate_Confluence</field>
    <comment pinned="false" h="80" w="160">Multi-Confluence System: Calcula score basado en múltiples indicadores</comment>
    <statement name="STACK">
      <block type="variables_set" id="RESET_CONF_SCORE">
        <field name="VAR" id="CONFLUENCE_001" variabletype="">Confluence_Score</field>
        <value name="VALUE">
          <block type="math_number" id="CONF_ZERO"><field name="NUM">0</field></block>
        </value>
        <next>
          <block type="controls_if" id="CONF_CHECK_1_SHORT">
            <mutation elseif="1"></mutation>
