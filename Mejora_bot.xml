            </statement>
            <next>
              <block type="controls_if" id="CONF_CHECK_2_STRONG">
                <mutation elseif="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="EVEN_VERY_HIGH">
                    <field name="OP">GTE</field>
                    <value name="A">
                      <block type="procedures_callreturn" id="CALL_EVEN_CONF2">
