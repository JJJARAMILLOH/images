  <block type="procedures_defnoreturn" id="PROC_CHECK_COOLDOWN" x="400" y="1200">
    <field name="NAME">Check_Cooldown</field>
    <comment pinned="false" h="80" w="160">Gestiona el sistema de cooldown - espera N ciclos antes de reactivar</comment>
    <statement name="STACK">
      <block type="controls_if" id="IF_COOLDOWN_ACTIVE">
        <value name="IF0">
          <block type="logic_compare" id="CD_IS_TRUE">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="GET_CD_STATUS">
                <field name="VAR" id="COOLDOWN_001" variabletype="">Cooldown_Active</field>
              </block>
            </value>
            <value name="B">
              <block type="logic_boolean" id="CD_TRUE_REF"><field name="BOOL">TRUE</field></block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="math_change" id="INC_CD_COUNTER">
            <field name="VAR" id="COOLDOWN_CNT_001" variabletype="">Cooldown_Counter</field>
            <value name="DELTA">
              <shadow type="math_number" id="CD_INC_VAL"><field name="NUM">1</field></shadow>
            </value>
            <next>
              <block type="controls_if" id="CHECK_CD_EXPIRED">
                <value name="IF0">
                  <block type="logic_operation" id="CD_EXPIRED_AND_SIGNAL">
                    <field name="OP">AND</field>
                    <value name="A">
                      <block type="logic_compare" id="CD_CNT_GTE_MAX">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_get" id="GET_CD_CNT">
                            <field name="VAR" id="COOLDOWN_CNT_001" variabletype="">Cooldown_Counter</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="GET_CD_MAX">
                            <field name="VAR" id="COOLDOWN_MAX_001" variabletype="">Cooldown_Max</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <value name="B">
                      <block type="logic_operation" id="SIGNAL_EXISTS">
                        <field name="OP">OR</field>
                        <value name="A">
                          <block type="logic_compare" id="EVEN_SIGNAL_CD">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="procedures_callreturn" id="CALL_EVEN_CD">
                                <mutation name="LD Even (%)"></mutation>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="CD_EVEN_THRESH"><field name="NUM">60</field></block>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="logic_compare" id="ODD_SIGNAL_CD">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="procedures_callreturn" id="CALL_ODD_CD">
                                <mutation name="LD Odd (%)"></mutation>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="CD_ODD_THRESH"><field name="NUM">60</field></block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="DEACTIVATE_CD">
                    <field name="VAR" id="COOLDOWN_001" variabletype="">Cooldown_Active</field>
                    <value name="VALUE">
                      <block type="logic_boolean" id="CD_FALSE_DEACT"><field name="BOOL">FALSE</field></block>
                    </value>
                    <next>
                      <block type="variables_set" id="DEACTIVATE_SKIP">
                        <field name="VAR" id="SKIP_TRADE_001" variabletype="">Skip_Trade</field>
                        <value name="VALUE">
                          <block type="logic_boolean" id="SKIP_FALSE_DEACT"><field name="BOOL">FALSE</field></block>
                        </value>
                        <next>
                          <block type="variables_set" id="RESET_CD_CNT">
                            <field name="VAR" id="COOLDOWN_CNT_001" variabletype="">Cooldown_Counter</field>
                            <value name="VALUE">
                              <block type="math_number" id="CD_CNT_ZERO"><field name="NUM">0</field></block>
                            </value>
                            <next>
